<UserControl x:Class="GalacticTrader.Desktop.Dashboard.DashboardPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   Margin="0,0,0,8">
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Foreground="#9DB7E2"
                       Text="Loading strategic summary..." />
            <Button x:Name="RefreshButton"
                    DockPanel.Dock="Right"
                    Width="128"
                    Height="30"
                    Background="#1F6FEB"
                    BorderBrush="#4A89F6"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Content="Refresh"
                    Click="OnRefreshClick" />
        </DockPanel>

        <UniformGrid Grid.Row="1"
                     Rows="2"
                     Columns="3">
            <Border Margin="0,0,8,8"
                    Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8"
                               Text="Wealth" />
                    <TextBlock x:Name="CreditsValue"
                               Foreground="#EAF2FF"
                               FontFamily="Consolas"
                               Text="-" />
                    <TextBlock x:Name="NetWorthValue"
                               Foreground="#9DB7E2"
                               Text="-" />
                    <TextBlock x:Name="TradeVolumeValue"
                               Foreground="#9DB7E2"
                               Text="-" />
                    <TextBlock x:Name="AssetMixValue"
                               Foreground="#9DB7E2"
                               Text="-" />
                    <ProgressBar x:Name="CashFlowBar"
                                 Margin="0,4,0,0"
                                 Height="6"
                                 Maximum="100"
                                 Value="0"
                                 Foreground="#1FD6B4"
                                 Background="#0A1630" />
                </StackPanel>
            </Border>

            <Border Margin="0,0,8,8"
                    Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8"
                               Text="Fleet" />
                    <TextBlock x:Name="FleetValue"
                               Foreground="#EAF2FF"
                               FontFamily="Consolas"
                               Text="-" />
                    <TextBlock x:Name="ShipCountValue"
                               Foreground="#9DB7E2"
                               Text="-" />
                    <TextBlock x:Name="RiskExposureValue"
                               Foreground="#9DB7E2"
                               Text="-" />
                    <ProgressBar x:Name="FleetRiskBar"
                                 Margin="0,4,0,0"
                                 Height="6"
                                 Maximum="100"
                                 Value="0"
                                 Foreground="#F59A23"
                                 Background="#0A1630" />
                </StackPanel>
            </Border>

            <Border Margin="0,0,0,8"
                    Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8"
                               Text="Reputation" />
                    <TextBlock x:Name="ReputationValue"
                               Foreground="#EAF2FF"
                               FontFamily="Consolas"
                               Text="-" />
                    <TextBlock x:Name="FactionAccessValue"
                               Foreground="#9DB7E2"
                               Text="-" />
                    <TextBlock x:Name="InfluenceIndexValue"
                               Foreground="#9DB7E2"
                               Text="-" />
                    <ProgressBar x:Name="ReputationInfluenceBar"
                                 Margin="0,4,0,0"
                                 Height="6"
                                 Maximum="100"
                                 Value="0"
                                 Foreground="#F2D06B"
                                 Background="#0A1630" />
                </StackPanel>
            </Border>

            <Border Margin="0,0,8,0"
                    Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8"
                               Text="Routes" />
                    <TextBlock x:Name="RoutesValue"
                               Foreground="#EAF2FF"
                               FontFamily="Consolas"
                               Text="-" />
                    <TextBlock x:Name="RiskRoutesValue"
                               Foreground="#9DB7E2"
                               Text="-" />
                    <TextBlock x:Name="RevenuePerRouteValue"
                               Foreground="#9DB7E2"
                               Text="-" />
                    <TextBlock x:Name="InterferenceValue"
                               Foreground="#9DB7E2"
                               Text="-" />
                    <ProgressBar x:Name="RouteInterferenceBar"
                                 Margin="0,4,0,0"
                                 Height="6"
                                 Maximum="100"
                                 Value="0"
                                 Foreground="#EC6B5F"
                                 Background="#0A1630" />
                </StackPanel>
            </Border>

            <Border Margin="0,0,8,0"
                    Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8"
                               Text="Intel" />
                    <TextBlock x:Name="IntelReportsValue"
                               Foreground="#EAF2FF"
                               FontFamily="Consolas"
                               Text="-" />
                    <TextBlock Foreground="#9DB7E2"
                               Text="Active reports" />
                </StackPanel>
            </Border>

            <Border Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8"
                               Text="Threats" />
                    <TextBlock x:Name="ThreatsValue"
                               Foreground="#EAF2FF"
                               FontFamily="Consolas"
                               Text="-" />
                    <TextBlock Foreground="#9DB7E2"
                               Text="Ranked alerts" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2"
                Margin="0,8,0,0"
                Padding="8"
                Background="#0E203D"
                BorderBrush="#2E4A75"
                BorderThickness="1"
                CornerRadius="6">
            <StackPanel>
                <TextBlock Foreground="#B9CBE8"
                           FontWeight="SemiBold"
                           Text="Global Strategic Metrics" />
                <UniformGrid Margin="0,8,0,0"
                             Rows="2"
                             Columns="3">
                    <StackPanel Margin="0,0,8,6">
                        <TextBlock Foreground="#9DB7E2"
                                   Text="Total Users" />
                        <TextBlock x:Name="GlobalUsersValue"
                                   Foreground="#EAF2FF"
                                   FontFamily="Consolas"
                                   Text="-" />
                    </StackPanel>
                    <StackPanel Margin="0,0,8,6">
                        <TextBlock Foreground="#9DB7E2"
                                   Text="Active Players (24h)" />
                        <TextBlock x:Name="GlobalActivePlayersValue"
                                   Foreground="#EAF2FF"
                                   FontFamily="Consolas"
                                   Text="-" />
                    </StackPanel>
                    <StackPanel Margin="0,0,0,6">
                        <TextBlock Foreground="#9DB7E2"
                                   Text="Avg Battles / Hour" />
                        <TextBlock x:Name="GlobalBattlesPerHourValue"
                                   Foreground="#EAF2FF"
                                   FontFamily="Consolas"
                                   Text="-" />
                    </StackPanel>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Foreground="#9DB7E2"
                                   Text="Economic Stability Index" />
                        <TextBlock x:Name="GlobalEconomicStabilityValue"
                                   Foreground="#EAF2FF"
                                   FontFamily="Consolas"
                                   Text="-" />
                    </StackPanel>
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Foreground="#9DB7E2"
                                   Text="Top Reputation Player" />
                        <TextBlock x:Name="GlobalTopReputationValue"
                                   Foreground="#EAF2FF"
                                   FontFamily="Consolas"
                                   Text="-" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Foreground="#9DB7E2"
                                   Text="Top Financial Player" />
                        <TextBlock x:Name="GlobalTopFinancialValue"
                                   Foreground="#EAF2FF"
                                   FontFamily="Consolas"
                                   Text="-" />
                    </StackPanel>
                </UniformGrid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
