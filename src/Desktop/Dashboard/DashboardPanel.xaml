<UserControl x:Class="GalacticTrader.Desktop.Dashboard.DashboardPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   Margin="0,0,0,8">
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Foreground="#9DB7E2"
                       Text="Loading strategic summary..." />
            <Button x:Name="RefreshButton"
                    DockPanel.Dock="Right"
                    Width="128"
                    Height="30"
                    Background="#1F6FEB"
                    BorderBrush="#4A89F6"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Content="Refresh"
                    Click="OnRefreshClick" />
        </DockPanel>

        <UniformGrid Grid.Row="1"
                     Rows="2"
                     Columns="3">
            <Border Margin="0,0,8,8"
                    Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8"
                               Text="Wealth" />
                    <TextBlock x:Name="CreditsValue"
                               Foreground="#EAF2FF"
                               FontFamily="Consolas"
                               Text="-" />
                    <TextBlock x:Name="TradeVolumeValue"
                               Foreground="#9DB7E2"
                               Text="-" />
                </StackPanel>
            </Border>

            <Border Margin="0,0,8,8"
                    Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8"
                               Text="Fleet" />
                    <TextBlock x:Name="FleetValue"
                               Foreground="#EAF2FF"
                               FontFamily="Consolas"
                               Text="-" />
                    <TextBlock x:Name="ShipCountValue"
                               Foreground="#9DB7E2"
                               Text="-" />
                </StackPanel>
            </Border>

            <Border Margin="0,0,0,8"
                    Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8"
                               Text="Reputation" />
                    <TextBlock x:Name="ReputationValue"
                               Foreground="#EAF2FF"
                               FontFamily="Consolas"
                               Text="-" />
                    <TextBlock x:Name="FactionAccessValue"
                               Foreground="#9DB7E2"
                               Text="-" />
                </StackPanel>
            </Border>

            <Border Margin="0,0,8,0"
                    Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8"
                               Text="Routes" />
                    <TextBlock x:Name="RoutesValue"
                               Foreground="#EAF2FF"
                               FontFamily="Consolas"
                               Text="-" />
                    <TextBlock x:Name="RiskRoutesValue"
                               Foreground="#9DB7E2"
                               Text="-" />
                </StackPanel>
            </Border>

            <Border Margin="0,0,8,0"
                    Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8"
                               Text="Intel" />
                    <TextBlock x:Name="IntelReportsValue"
                               Foreground="#EAF2FF"
                               FontFamily="Consolas"
                               Text="-" />
                    <TextBlock Foreground="#9DB7E2"
                               Text="Active reports" />
                </StackPanel>
            </Border>

            <Border Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8"
                               Text="Threats" />
                    <TextBlock x:Name="ThreatsValue"
                               Foreground="#EAF2FF"
                               FontFamily="Consolas"
                               Text="-" />
                    <TextBlock Foreground="#9DB7E2"
                               Text="Ranked alerts" />
                </StackPanel>
            </Border>
        </UniformGrid>
    </Grid>
</UserControl>
