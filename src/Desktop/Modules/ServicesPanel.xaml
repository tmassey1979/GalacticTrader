<UserControl x:Class="GalacticTrader.Desktop.Modules.ServicesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   Margin="0,0,0,6">
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Foreground="#9DB7E2"
                       Text="Loading NPC services..." />
            <Button x:Name="ClearBlacklistButton"
                    DockPanel.Dock="Right"
                    Width="120"
                    Height="28"
                    Margin="6,0,0,0"
                    Background="#2D3D57"
                    BorderBrush="#4C607F"
                    Foreground="#EAF2FF"
                    Content="Clear Blacklist"
                    Click="OnClearBlacklistClick" />
            <Button x:Name="RefreshButton"
                    DockPanel.Dock="Right"
                    Width="120"
                    Height="28"
                    Background="#1F6FEB"
                    BorderBrush="#4A89F6"
                    Foreground="White"
                    Content="Refresh"
                    Click="OnRefreshClick" />
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0"
                      x:Name="AgentsGrid"
                      Background="#0C152A"
                      BorderBrush="#2F4B78"
                      Foreground="#DCE7FF"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      SelectionChanged="OnAgentSelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Agent"
                                        Binding="{Binding Name}"
                                        Width="*" />
                    <DataGridTextColumn Header="Archetype"
                                        Binding="{Binding Archetype}"
                                        Width="100" />
                    <DataGridTextColumn Header="Influence"
                                        Binding="{Binding InfluenceScore, StringFormat={}{0:N2}}"
                                        Width="75" />
                    <DataGridTextColumn Header="Aggression"
                                        Binding="{Binding AggressionIndex}"
                                        Width="75" />
                    <DataGridTextColumn Header="Bias"
                                        Binding="{Binding StrategyBias}"
                                        Width="120" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="2"
                    Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8"
                               FontWeight="SemiBold"
                               Text="Selected Agent" />
                    <TextBlock x:Name="SelectedAgentText"
                               Margin="0,4,0,8"
                               Foreground="#EAF2FF"
                               TextWrapping="Wrap"
                               Text="Select an NPC agent." />

                    <TextBlock Foreground="#B9CBE8"
                               Text="Actions" />
                    <StackPanel Orientation="Horizontal"
                                Margin="0,4,0,0">
                        <Button x:Name="OfferContractButton"
                                Width="100"
                                Height="28"
                                Margin="0,0,6,0"
                                Background="#00A86B"
                                BorderBrush="#20C284"
                                Foreground="White"
                                Content="Offer Contract"
                                Click="OnOfferContractClick" />
                        <Button x:Name="NegotiateProtectionButton"
                                Width="120"
                                Height="28"
                                Margin="0,0,6,0"
                                Background="#1F6FEB"
                                BorderBrush="#4A89F6"
                                Foreground="White"
                                Content="Protection"
                                Click="OnNegotiateProtectionClick" />
                        <Button x:Name="BlacklistButton"
                                Width="80"
                                Height="28"
                                Background="#B14545"
                                BorderBrush="#D16D6D"
                                Foreground="White"
                                Content="Blacklist"
                                Click="OnBlacklistClick" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
