<UserControl x:Class="GalacticTrader.Desktop.Modules.TerritoryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   Margin="0,0,0,6">
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Foreground="#9DB7E2"
                       Text="Loading territory dominance..." />
            <Button x:Name="RefreshButton"
                    DockPanel.Dock="Right"
                    Width="120"
                    Height="28"
                    Background="#1F6FEB"
                    BorderBrush="#4A89F6"
                    Foreground="White"
                    Content="Refresh"
                    Click="OnRefreshClick" />
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0"
                      x:Name="TerritoryGrid"
                      Background="#0C152A"
                      BorderBrush="#2F4B78"
                      Foreground="#DCE7FF"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      SelectionChanged="OnTerritorySelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Faction"
                                        Binding="{Binding FactionName}"
                                        Width="*" />
                    <DataGridTextColumn Header="Sectors"
                                        Binding="{Binding ControlledSectorCount}"
                                        Width="70" />
                    <DataGridTextColumn Header="Infra"
                                        Binding="{Binding InfrastructureControlScore, StringFormat={}{0:N1}}"
                                        Width="70" />
                    <DataGridTextColumn Header="Momentum"
                                        Binding="{Binding WarMomentumScore, StringFormat={}{0:N1}}"
                                        Width="80" />
                    <DataGridTextColumn Header="Dominance"
                                        Binding="{Binding DominanceScore, StringFormat={}{0:N1}}"
                                        Width="80" />
                    <DataGridTextColumn Header="Heat"
                                        Binding="{Binding HeatHex}"
                                        Width="80" />
                    <DataGridTextColumn Header="Priority"
                                        Binding="{Binding ProtectionPriority}"
                                        Width="70" />
                    <DataGridTextColumn Header="Output/System"
                                        Binding="{Binding EconomicOutputPerSystem, StringFormat={}{0:N2}}"
                                        Width="96" />
                    <DataGridTextColumn Header="Tax %"
                                        Binding="{Binding TaxRatePercent, StringFormat={}{0:N1}}"
                                        Width="70" />
                    <DataGridTextColumn Header="Incentive %"
                                        Binding="{Binding TradeIncentivePercent, StringFormat={}{0:N1}}"
                                        Width="90" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="2"
                    Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8"
                               FontWeight="SemiBold"
                               Text="Territory Heatmap Control" />
                    <TextBlock x:Name="SelectedTerritoryText"
                               Margin="0,4,0,8"
                               Foreground="#EAF2FF"
                               TextWrapping="Wrap"
                               Text="Select a faction row." />

                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="#B9CBE8"
                                   Text="Protection" />
                        <ComboBox x:Name="ProtectionPriorityCombo"
                                  Width="90"
                                  Height="28"
                                  Margin="8,0,0,0"
                                  Background="#101F39"
                                  BorderBrush="#2E4A75"
                                  Foreground="#EAF2FF">
                            <ComboBoxItem IsSelected="True" Content="Low" />
                            <ComboBoxItem Content="Medium" />
                            <ComboBoxItem Content="High" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                Margin="0,8,0,0">
                        <Button x:Name="AssignProtectionButton"
                                Width="125"
                                Height="28"
                                Margin="0,0,6,0"
                                Background="#00A86B"
                                BorderBrush="#20C284"
                                Foreground="White"
                                Content="Assign Protection"
                                Click="OnAssignProtectionClick" />
                        <Button x:Name="RecalculateButton"
                                Width="95"
                                Height="28"
                                Background="#1F6FEB"
                                BorderBrush="#4A89F6"
                                Foreground="White"
                                Content="Recalculate"
                                Click="OnRecalculateClick" />
                    </StackPanel>

                    <Border Margin="0,10,0,0"
                            Padding="8"
                            Background="#11274A"
                            BorderBrush="#2E4A75"
                            BorderThickness="1"
                            CornerRadius="4">
                        <StackPanel>
                            <TextBlock Foreground="#B9CBE8"
                                       FontWeight="SemiBold"
                                       Text="Economic Policy" />
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,6,0,0">
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="#B9CBE8"
                                           Text="Tax %" />
                                <TextBox x:Name="TaxRateTextBox"
                                         Width="60"
                                         Height="26"
                                         Margin="8,0,10,0"
                                         Text="10.0"
                                         Background="#101F39"
                                         BorderBrush="#2E4A75"
                                         Foreground="#EAF2FF" />
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="#B9CBE8"
                                           Text="Incentive %" />
                                <TextBox x:Name="TradeIncentiveTextBox"
                                         Width="70"
                                         Height="26"
                                         Margin="8,0,0,0"
                                         Text="0.0"
                                         Background="#101F39"
                                         BorderBrush="#2E4A75"
                                         Foreground="#EAF2FF" />
                            </StackPanel>
                            <Button x:Name="ApplyEconomicPolicyButton"
                                    Width="170"
                                    Height="28"
                                    Margin="0,8,0,0"
                                    HorizontalAlignment="Left"
                                    Background="#8C4A11"
                                    BorderBrush="#B96E22"
                                    Foreground="White"
                                    Content="Apply Economic Policy"
                                    Click="OnApplyEconomicPolicyClick" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
