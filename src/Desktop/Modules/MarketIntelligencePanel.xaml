<UserControl x:Class="GalacticTrader.Desktop.Modules.MarketIntelligencePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   Margin="0,0,0,8">
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Foreground="#9DB7E2"
                       Text="Loading market intelligence..." />
            <Button x:Name="RefreshButton"
                    DockPanel.Dock="Right"
                    Width="128"
                    Height="30"
                    Background="#1F6FEB"
                    BorderBrush="#4A89F6"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Content="Refresh"
                    Click="OnRefreshClick" />
        </DockPanel>

        <Border Grid.Row="1"
                Padding="8"
                Margin="0,0,0,8"
                Background="#0E203D"
                BorderBrush="#2E4A75"
                BorderThickness="1"
                CornerRadius="6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Foreground="#B9CBE8"
                           Text="Price Volatility Index:"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="VolatilityValue"
                           Margin="8,0,0,0"
                           Foreground="#EAF2FF"
                           FontFamily="Consolas"
                           Text="-" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2"
              Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Foreground="#B9CBE8"
                               FontWeight="SemiBold"
                               Text="Regional Heatmap" />
                    <DataGrid Grid.Row="1"
                              x:Name="HeatmapGrid"
                              Margin="0,8,0,0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              Background="#08182F"
                              BorderBrush="#2E4A75"
                              Foreground="#EAF2FF"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Sector"
                                                Binding="{Binding SectorName}"
                                                Width="*" />
                            <DataGridTextColumn Header="Volume"
                                                Binding="{Binding TradeVolume, StringFormat=N2}"
                                                Width="100" />
                            <DataGridTextColumn Header="Trades"
                                                Binding="{Binding TradeCount}"
                                                Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Foreground="#B9CBE8"
                               FontWeight="SemiBold"
                               Text="Top Traders" />
                    <DataGrid Grid.Row="1"
                              x:Name="TopTradersGrid"
                              Margin="0,8,0,0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              Background="#08182F"
                              BorderBrush="#2E4A75"
                              Foreground="#EAF2FF"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Trader"
                                                Binding="{Binding Username}"
                                                Width="*" />
                            <DataGridTextColumn Header="Volume"
                                                Binding="{Binding TradeVolume, StringFormat=N2}"
                                                Width="100" />
                            <DataGridTextColumn Header="Trades"
                                                Binding="{Binding TradeCount}"
                                                Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Background="#0E203D"
                BorderBrush="#2E4A75"
                BorderThickness="1"
                CornerRadius="6"
                Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Foreground="#B9CBE8"
                               FontWeight="SemiBold"
                               Text="Emerging Smuggling Corridors" />
                    <DataGrid Grid.Row="1"
                              x:Name="CorridorsGrid"
                              Margin="0,8,0,0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              Background="#08182F"
                              BorderBrush="#2E4A75"
                              Foreground="#EAF2FF"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Corridor"
                                                Binding="{Binding Corridor}"
                                                Width="*" />
                            <DataGridTextColumn Header="Runs"
                                                Binding="{Binding SmugglingRuns}"
                                                Width="80" />
                            <DataGridTextColumn Header="Avg Value"
                                                Binding="{Binding AverageTradeValue, StringFormat=N2}"
                                                Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Foreground="#B9CBE8"
                               FontWeight="SemiBold"
                               Text="Trade Flow Diagrams" />
                    <DataGrid Grid.Row="1"
                              x:Name="TradeFlowGrid"
                              Margin="0,8,0,0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              Background="#08182F"
                              BorderBrush="#2E4A75"
                              Foreground="#EAF2FF"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Flow"
                                                Binding="{Binding Flow}"
                                                Width="*" />
                            <DataGridTextColumn Header="Index"
                                                Binding="{Binding FlowIndex, StringFormat=N1}"
                                                Width="80" />
                            <DataGridTextColumn Header="Diagram"
                                                Binding="{Binding Diagram}"
                                                Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
