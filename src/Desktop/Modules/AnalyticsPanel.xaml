<UserControl x:Class="GalacticTrader.Desktop.Modules.AnalyticsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   Margin="0,0,0,6">
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Foreground="#9DB7E2"
                       Text="Loading analytics..." />
            <Button x:Name="RefreshButton"
                    DockPanel.Dock="Right"
                    Width="120"
                    Height="28"
                    Background="#1F6FEB"
                    BorderBrush="#4A89F6"
                    Foreground="White"
                    Content="Refresh"
                    Click="OnRefreshClick" />
        </DockPanel>

        <UniformGrid Grid.Row="1"
                     Rows="2"
                     Columns="3">
            <Border Margin="0,0,8,8"
                    Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8" Text="Revenue Volume" />
                    <TextBlock x:Name="RevenueText" Foreground="#EAF2FF" FontFamily="Consolas" Text="-" />
                </StackPanel>
            </Border>
            <Border Margin="0,0,8,8"
                    Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8" Text="Trades" />
                    <TextBlock x:Name="TradesText" Foreground="#EAF2FF" FontFamily="Consolas" Text="-" />
                </StackPanel>
            </Border>
            <Border Margin="0,0,0,8"
                    Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8" Text="Avg Trade" />
                    <TextBlock x:Name="AvgTradeText" Foreground="#EAF2FF" FontFamily="Consolas" Text="-" />
                </StackPanel>
            </Border>
            <Border Margin="0,0,8,0"
                    Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8" Text="Combats" />
                    <TextBlock x:Name="CombatsText" Foreground="#EAF2FF" FontFamily="Consolas" Text="-" />
                </StackPanel>
            </Border>
            <Border Margin="0,0,8,0"
                    Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8" Text="Avg Duration" />
                    <TextBlock x:Name="AvgDurationText" Foreground="#EAF2FF" FontFamily="Consolas" Text="-" />
                </StackPanel>
            </Border>
            <Border Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8" Text="Insurance Paid" />
                    <TextBlock x:Name="InsuranceText" Foreground="#EAF2FF" FontFamily="Consolas" Text="-" />
                </StackPanel>
            </Border>
        </UniformGrid>
    </Grid>
</UserControl>
