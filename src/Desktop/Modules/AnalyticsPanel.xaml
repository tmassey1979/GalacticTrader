<UserControl x:Class="GalacticTrader.Desktop.Modules.AnalyticsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="110" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   Margin="0,0,0,6">
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Foreground="#9DB7E2"
                       Text="Loading analytics..." />
            <Button x:Name="ExportButton"
                    DockPanel.Dock="Right"
                    Width="120"
                    Height="28"
                    Margin="6,0,0,0"
                    Background="#00A86B"
                    BorderBrush="#20C284"
                    Foreground="White"
                    Content="Export CSV"
                    Click="OnExportClick" />
            <Button x:Name="RefreshButton"
                    DockPanel.Dock="Right"
                    Width="120"
                    Height="28"
                    Background="#1F6FEB"
                    BorderBrush="#4A89F6"
                    Foreground="White"
                    Content="Refresh"
                    Click="OnRefreshClick" />
        </DockPanel>

        <UniformGrid Grid.Row="1"
                     Rows="2"
                     Columns="3">
            <Border Margin="0,0,8,8"
                    Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8" Text="Revenue Volume" />
                    <TextBlock x:Name="RevenueText" Foreground="#EAF2FF" FontFamily="Consolas" Text="-" />
                </StackPanel>
            </Border>
            <Border Margin="0,0,8,8"
                    Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8" Text="Trades" />
                    <TextBlock x:Name="TradesText" Foreground="#EAF2FF" FontFamily="Consolas" Text="-" />
                </StackPanel>
            </Border>
            <Border Margin="0,0,0,8"
                    Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8" Text="Avg Trade" />
                    <TextBlock x:Name="AvgTradeText" Foreground="#EAF2FF" FontFamily="Consolas" Text="-" />
                </StackPanel>
            </Border>
            <Border Margin="0,0,8,0"
                    Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8" Text="Combats" />
                    <TextBlock x:Name="CombatsText" Foreground="#EAF2FF" FontFamily="Consolas" Text="-" />
                </StackPanel>
            </Border>
            <Border Margin="0,0,8,0"
                    Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8" Text="Avg Duration" />
                    <TextBlock x:Name="AvgDurationText" Foreground="#EAF2FF" FontFamily="Consolas" Text="-" />
                </StackPanel>
            </Border>
            <Border Padding="8"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="#B9CBE8" Text="Insurance Paid" />
                    <TextBlock x:Name="InsuranceText" Foreground="#EAF2FF" FontFamily="Consolas" Text="-" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2"
                Padding="8"
                Margin="0,6,0,0"
                Background="#0E203D"
                BorderBrush="#2E4A75"
                BorderThickness="1"
                CornerRadius="6">
            <StackPanel>
                <WrapPanel Margin="0,0,0,6">
                    <TextBlock Foreground="#B9CBE8"
                               Text="Risk Adj Return:" />
                    <TextBlock x:Name="RiskAdjustedReturnText"
                               Margin="6,0,14,0"
                               Foreground="#EAF2FF"
                               FontFamily="Consolas"
                               Text="-" />
                    <TextBlock Foreground="#B9CBE8"
                               Text="Battle/Profit:" />
                    <TextBlock x:Name="BattleToProfitText"
                               Margin="6,0,14,0"
                               Foreground="#EAF2FF"
                               FontFamily="Consolas"
                               Text="-" />
                    <TextBlock Foreground="#B9CBE8"
                               Text="ROI/Ship:" />
                    <TextBlock x:Name="RoiPerShipText"
                               Margin="6,0,14,0"
                               Foreground="#EAF2FF"
                               FontFamily="Consolas"
                               Text="-" />
                    <TextBlock Foreground="#B9CBE8"
                               Text="Market Share:" />
                    <TextBlock x:Name="MarketShareText"
                               Margin="6,0,14,0"
                               Foreground="#EAF2FF"
                               FontFamily="Consolas"
                               Text="-" />
                    <TextBlock Foreground="#B9CBE8"
                               Text="Influence:" />
                    <TextBlock x:Name="SystemInfluenceText"
                               Margin="6,0,0,0"
                               Foreground="#EAF2FF"
                               FontFamily="Consolas"
                               Text="-" />
                </WrapPanel>
                <TextBlock Foreground="#B9CBE8"
                           Margin="0,0,0,4"
                           Text="Revenue Trend (latest trades)" />
                <ItemsControl x:Name="TrendBars"
                              Height="76">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid VerticalAlignment="Bottom">
                                <Rectangle Fill="#55A9F5"
                                           VerticalAlignment="Bottom"
                                           Height="{Binding Height}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
