<UserControl x:Class="GalacticTrader.Desktop.Fleet.FleetPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   Margin="0,0,0,10">
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Foreground="#9DB7E2"
                       Text="Loading fleet data..." />
            <Button x:Name="RefreshButton"
                    DockPanel.Dock="Right"
                    Width="128"
                    Height="34"
                    Background="#1F6FEB"
                    BorderBrush="#4A89F6"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Content="Refresh Fleet"
                    Click="OnRefreshClick" />
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0"
                      x:Name="ShipsGrid"
                      Background="#0C152A"
                      BorderBrush="#2F4B78"
                      Foreground="#DCE7FF"
                      HeadersVisibility="Column"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      SelectionChanged="OnShipSelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Ship"
                                        Binding="{Binding Name}"
                                        Width="*" />
                    <DataGridTextColumn Header="Class"
                                        Binding="{Binding ShipClass}"
                                        Width="130" />
                    <DataGridTextColumn Header="Hull"
                                        Binding="{Binding HullIntegrity}"
                                        Width="70" />
                    <DataGridTextColumn Header="Max"
                                        Binding="{Binding MaxHullIntegrity}"
                                        Width="70" />
                    <DataGridTextColumn Header="Cargo"
                                        Binding="{Binding CargoCapacity}"
                                        Width="70" />
                    <DataGridTextColumn Header="Mods"
                                        Binding="{Binding ModuleCount}"
                                        Width="60" />
                    <DataGridTextColumn Header="Eco Eff"
                                        Binding="{Binding EconomicEfficiencyScore, StringFormat={}{0:N2}}"
                                        Width="72" />
                    <DataGridTextColumn Header="Crew"
                                        Binding="{Binding CrewAssignment}"
                                        Width="100" />
                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding CrewStatus}"
                                        Width="100" />
                    <DataGridTextColumn Header="Insurance"
                                        Binding="{Binding InsuranceStatus}"
                                        Width="110" />
                    <DataGridTextColumn Header="Assigned Route"
                                        Binding="{Binding AssignedRoute}"
                                        Width="180" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="2"
                    Padding="10"
                    Background="#0E203D"
                    BorderBrush="#2E4A75"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Text="Selected Ship Loadout"
                               Foreground="#D5E3FF"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="SelectedShipText"
                               Margin="0,6,0,8"
                               Foreground="#EAF2FF"
                               TextWrapping="Wrap"
                               Text="Select a ship to inspect modules." />

                    <TextBlock Text="Modules"
                               Foreground="#B9CBE8"
                               FontWeight="SemiBold" />
                    <ListBox x:Name="ModulesList"
                             Height="160"
                             Margin="0,6,0,10"
                             Background="#101F39"
                             BorderBrush="#2E4A75"
                             Foreground="#EAF2FF" />

                    <TextBlock Text="Route Performance History"
                               Foreground="#B9CBE8"
                               FontWeight="SemiBold" />
                    <ListBox x:Name="RouteHistoryList"
                             Height="120"
                             Margin="0,6,0,10"
                             Background="#101F39"
                             BorderBrush="#2E4A75"
                             Foreground="#EAF2FF">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontFamily="Consolas"
                                           Text="{Binding}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Text="Escort Summary"
                               Foreground="#B9CBE8"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="EscortSummaryText"
                               Margin="0,6,0,0"
                               Foreground="#EAF2FF"
                               TextWrapping="Wrap"
                               Text="Escort summary unavailable." />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
