<UserControl x:Class="GalacticTrader.Desktop.Intel.IntelPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   Margin="0,0,0,10">
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Foreground="#9DB7E2"
                       Text="Loading intelligence data..." />
            <Button x:Name="RefreshButton"
                    DockPanel.Dock="Right"
                    Width="128"
                    Height="34"
                    Background="#1F6FEB"
                    BorderBrush="#4A89F6"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Content="Refresh Intel"
                    Click="OnRefreshClick" />
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0"
                          x:Name="StandingsGrid"
                          Background="#0C152A"
                          BorderBrush="#2F4B78"
                          Foreground="#DCE7FF"
                          HeadersVisibility="Column"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Faction"
                                            Binding="{Binding FactionId}"
                                            Width="*" />
                        <DataGridTextColumn Header="Rep"
                                            Binding="{Binding ReputationScore}"
                                            Width="70" />
                        <DataGridTextColumn Header="Tier"
                                            Binding="{Binding Tier}"
                                            Width="90" />
                        <DataGridTextColumn Header="Access"
                                            Binding="{Binding Access}"
                                            Width="80" />
                        <DataGridTextColumn Header="Discount"
                                            Binding="{Binding TradingDiscount, StringFormat={}{0:P1}}"
                                            Width="90" />
                        <DataGridTextColumn Header="Tax Mod"
                                            Binding="{Binding TaxModifier, StringFormat={}{0:P1}}"
                                            Width="90" />
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="2"
                        Padding="8"
                        BorderBrush="#2E4A75"
                        BorderThickness="1"
                        CornerRadius="6"
                        Background="#0E203D">
                    <StackPanel>
                        <TextBlock Text="Faction Benefits"
                                   Foreground="#B9CBE8"
                                   FontWeight="SemiBold" />
                        <ListBox x:Name="BenefitsList"
                                 Margin="0,6,0,0"
                                 Background="#101F39"
                                 BorderBrush="#2E4A75"
                                 Foreground="#EAF2FF" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0"
                          x:Name="ThreatGrid"
                          Background="#0C152A"
                          BorderBrush="#2F4B78"
                          Foreground="#DCE7FF"
                          HeadersVisibility="Column"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Source"
                                            Binding="{Binding Source}"
                                            Width="80" />
                        <DataGridTextColumn Header="Severity"
                                            Binding="{Binding Severity, StringFormat={}{0:N1}}"
                                            Width="80" />
                        <DataGridTextColumn Header="Headline"
                                            Binding="{Binding Headline}"
                                            Width="*" />
                    </DataGrid.Columns>
                </DataGrid>

                <DataGrid Grid.Row="2"
                          x:Name="ReportsGrid"
                          Background="#0C152A"
                          BorderBrush="#2F4B78"
                          Foreground="#DCE7FF"
                          HeadersVisibility="Column"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Signal"
                                            Binding="{Binding SignalType}"
                                            Width="90" />
                        <DataGridTextColumn Header="Sector"
                                            Binding="{Binding SectorName}"
                                            Width="100" />
                        <DataGridTextColumn Header="Conf."
                                            Binding="{Binding ConfidenceScore, StringFormat={}{0:P1}}"
                                            Width="80" />
                        <DataGridTextColumn Header="Payload"
                                            Binding="{Binding Payload}"
                                            Width="*" />
                        <DataGridTextColumn Header="Expires UTC"
                                            Binding="{Binding ExpiresAtUtc}"
                                            Width="160" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
