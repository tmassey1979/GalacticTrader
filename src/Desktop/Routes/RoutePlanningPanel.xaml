<UserControl x:Class="GalacticTrader.Desktop.Routes.RoutePlanningPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0"
                   Margin="0,0,0,8">
            <StackPanel Margin="0,0,8,0">
                <TextBlock Foreground="#B9CBE8"
                           Text="From" />
                <ComboBox x:Name="FromSectorCombo"
                          Width="140"
                          Height="30"
                          DisplayMemberPath="Name"
                          SelectedValuePath="SectorId"
                          Background="#101F39"
                          BorderBrush="#2E4A75"
                          Foreground="#EAF2FF" />
            </StackPanel>
            <StackPanel Margin="0,0,8,0">
                <TextBlock Foreground="#B9CBE8"
                           Text="To" />
                <ComboBox x:Name="ToSectorCombo"
                          Width="140"
                          Height="30"
                          DisplayMemberPath="Name"
                          SelectedValuePath="SectorId"
                          Background="#101F39"
                          BorderBrush="#2E4A75"
                          Foreground="#EAF2FF" />
            </StackPanel>
            <StackPanel Margin="0,0,8,0">
                <TextBlock Foreground="#B9CBE8"
                           Text="Waypoints" />
                <TextBox x:Name="WaypointsText"
                         Width="220"
                         Height="30"
                         ToolTip="Comma-separated sector names"
                         Background="#101F39"
                         BorderBrush="#2E4A75"
                         Foreground="#EAF2FF"
                         VerticalContentAlignment="Center" />
            </StackPanel>
            <StackPanel Margin="0,0,8,0">
                <TextBlock Foreground="#B9CBE8"
                           Text="Mode" />
                <ComboBox x:Name="TravelModeCombo"
                          Width="130"
                          Height="30"
                          Background="#101F39"
                          BorderBrush="#2E4A75"
                          Foreground="#EAF2FF">
                    <ComboBoxItem Content="Safe Route" />
                    <ComboBoxItem IsSelected="True" Content="Balanced Route" />
                    <ComboBoxItem Content="High Profit Route" />
                    <ComboBoxItem Content="Smuggler Route" />
                </ComboBox>
            </StackPanel>
            <StackPanel Margin="0,0,8,0">
                <TextBlock Foreground="#B9CBE8"
                           Text="Algorithm" />
                <ComboBox x:Name="AlgorithmCombo"
                          Width="110"
                          Height="30"
                          Background="#101F39"
                          BorderBrush="#2E4A75"
                          Foreground="#EAF2FF">
                    <ComboBoxItem IsSelected="True" Content="dijkstra" />
                    <ComboBoxItem Content="astar" />
                </ComboBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal"
                        Margin="0,20,0,0">
                <Button x:Name="CalculateButton"
                        Width="120"
                        Height="30"
                        Margin="0,0,8,0"
                        Background="#1F6FEB"
                        BorderBrush="#4A89F6"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Content="Calculate"
                        Click="OnCalculateClick" />
                <Button x:Name="OptimizeButton"
                        Width="120"
                        Height="30"
                        Background="#00A86B"
                        BorderBrush="#20C284"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Content="Optimize"
                        Click="OnOptimizeClick" />
            </StackPanel>
        </WrapPanel>

        <Border Grid.Row="1"
                Margin="0,0,0,8"
                Padding="8"
                Background="#0E203D"
                BorderBrush="#2E4A75"
                BorderThickness="1"
                CornerRadius="6">
            <StackPanel>
                <TextBlock x:Name="StatusText"
                           Foreground="#9DB7E2"
                           Text="Load sectors to begin planning." />
                <TextBlock x:Name="PlanSummaryText"
                           Margin="0,4,0,0"
                           Foreground="#EAF2FF"
                           FontFamily="Consolas"
                           Text="No route plan yet." />
                <TextBlock x:Name="RiskSummaryText"
                           Margin="0,4,0,0"
                           Foreground="#EAF2FF"
                           FontFamily="Consolas"
                           Text="No risk simulation yet." />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0"
                      x:Name="HopsGrid"
                      Background="#0C152A"
                      BorderBrush="#2F4B78"
                      Foreground="#DCE7FF"
                      HeadersVisibility="Column"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Segment"
                                        Binding="{Binding Segment}"
                                        Width="*" />
                    <DataGridTextColumn Header="Time (s)"
                                        Binding="{Binding TravelTimeSeconds}"
                                        Width="80" />
                    <DataGridTextColumn Header="Fuel"
                                        Binding="{Binding FuelCost, StringFormat={}{0:N1}}"
                                        Width="70" />
                    <DataGridTextColumn Header="Risk"
                                        Binding="{Binding RiskScore, StringFormat={}{0:N1}}"
                                        Width="70" />
                    <DataGridTextColumn Header="Density"
                                        Binding="{Binding EconomicDensity, StringFormat={}{0:N1}}"
                                        Width="78" />
                    <DataGridTextColumn Header="Pirate %"
                                        Binding="{Binding PiratePresenceProbability, StringFormat={}{0:N1}}"
                                        Width="82" />
                </DataGrid.Columns>
            </DataGrid>

            <DataGrid Grid.Column="2"
                      x:Name="OptimizationGrid"
                      Background="#0C152A"
                      BorderBrush="#2F4B78"
                      Foreground="#DCE7FF"
                      HeadersVisibility="Column"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Profile"
                                        Binding="{Binding Profile}"
                                        Width="90" />
                    <DataGridTextColumn Header="Time (s)"
                                        Binding="{Binding TravelTimeSeconds}"
                                        Width="70" />
                    <DataGridTextColumn Header="Fuel"
                                        Binding="{Binding FuelCost, StringFormat={}{0:N1}}"
                                        Width="70" />
                    <DataGridTextColumn Header="Risk"
                                        Binding="{Binding RiskScore, StringFormat={}{0:N1}}"
                                        Width="70" />
                    <DataGridTextColumn Header="Cost"
                                        Binding="{Binding TotalCost, StringFormat={}{0:N1}}"
                                        Width="80" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
