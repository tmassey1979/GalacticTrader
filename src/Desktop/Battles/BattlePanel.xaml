<UserControl x:Class="GalacticTrader.Desktop.Battles.BattlePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   Margin="0,0,0,8">
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Foreground="#9DB7E2"
                       Text="Loading battle feed..." />
            <Button x:Name="RefreshButton"
                    DockPanel.Dock="Right"
                    Width="128"
                    Height="30"
                    Background="#1F6FEB"
                    BorderBrush="#4A89F6"
                    Foreground="White"
                    FontWeight="SemiBold"
                    Content="Refresh"
                    Click="OnRefreshClick" />
        </DockPanel>

        <DataGrid Grid.Row="1"
                  x:Name="BattleGrid"
                  Background="#0C152A"
                  BorderBrush="#2F4B78"
                  Foreground="#DCE7FF"
                  HeadersVisibility="Column"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Ended UTC"
                                    Binding="{Binding EndedAtUtc, StringFormat={}{0:u}}"
                                    Width="170" />
                <DataGridTextColumn Header="Outcome"
                                    Binding="{Binding Outcome}"
                                    Width="100" />
                <DataGridTextColumn Header="Duration"
                                    Binding="{Binding DurationSeconds}"
                                    Width="80" />
                <DataGridTextColumn Header="Ticks"
                                    Binding="{Binding TotalTicks}"
                                    Width="70" />
                <DataGridTextColumn Header="Attacker"
                                    Binding="{Binding Attacker}"
                                    Width="90" />
                <DataGridTextColumn Header="Defender"
                                    Binding="{Binding Defender}"
                                    Width="90" />
                <DataGridTextColumn Header="Insurance"
                                    Binding="{Binding InsurancePayout, StringFormat={}{0:N2}}"
                                    Width="90" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
