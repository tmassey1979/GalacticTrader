<Window x:Class="GalacticTrader.Desktop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Galactic Trader // Auth Terminal"
        Width="620"
        Height="470"
        MinWidth="620"
        MinHeight="470"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#060C09">
    <Window.Resources>
        <Style x:Key="TerminalLabelStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="#78F2A4" />
            <Setter Property="FontFamily"
                    Value="Consolas" />
            <Setter Property="FontSize"
                    Value="15" />
            <Setter Property="Margin"
                    Value="0,0,0,8" />
        </Style>

        <Style x:Key="TerminalTextBoxStyle"
               TargetType="TextBox">
            <Setter Property="Height"
                    Value="44" />
            <Setter Property="Padding"
                    Value="12,8" />
            <Setter Property="Background"
                    Value="#0E1A13" />
            <Setter Property="Foreground"
                    Value="#C6FFD9" />
            <Setter Property="BorderBrush"
                    Value="#2D7D4C" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="FontFamily"
                    Value="Consolas" />
            <Setter Property="FontSize"
                    Value="18" />
        </Style>

        <Style x:Key="TerminalPasswordBoxStyle"
               TargetType="PasswordBox">
            <Setter Property="Height"
                    Value="44" />
            <Setter Property="Padding"
                    Value="12,8" />
            <Setter Property="Background"
                    Value="#0E1A13" />
            <Setter Property="Foreground"
                    Value="#C6FFD9" />
            <Setter Property="BorderBrush"
                    Value="#2D7D4C" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="FontFamily"
                    Value="Consolas" />
            <Setter Property="FontSize"
                    Value="18" />
        </Style>

        <Style x:Key="TerminalButtonStyle"
               TargetType="Button">
            <Setter Property="Height"
                    Value="42" />
            <Setter Property="FontFamily"
                    Value="Consolas" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="FontSize"
                    Value="15" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Border CornerRadius="10"
                Background="#08120E"
                BorderBrush="#1B3829"
                BorderThickness="1" />
        <Rectangle Margin="1"
                   RadiusX="10"
                   RadiusY="10"
                   IsHitTestVisible="False">
            <Rectangle.Fill>
                <VisualBrush TileMode="Tile"
                            ViewportUnits="Absolute"
                            Viewport="0,0,5,5"
                            Opacity="0.08">
                    <VisualBrush.Visual>
                        <Rectangle Width="5"
                                   Height="5"
                                   Fill="#64FF9A" />
                    </VisualBrush.Visual>
                </VisualBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Border Margin="8"
                BorderBrush="#2D7D4C"
                BorderThickness="1.2"
                CornerRadius="8"
                Padding="18"
                Background="#07100C">
            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Foreground="#8EFFB5"
                       FontFamily="Consolas"
                       FontSize="26"
                       FontWeight="Bold"
                       Text="GALACTIC TRADER // AUTH TERMINAL" />
            <TextBlock Grid.Row="1"
                       Margin="0,6,0,0"
                       Foreground="#72BE91"
                       FontFamily="Consolas"
                       FontSize="15"
                       Text="Establish pilot credentials before launching command interface." />
            <TextBlock x:Name="ApiBaseUrlText"
                       Grid.Row="2"
                       Margin="0,6,0,18"
                       Foreground="#58D48C"
                       FontFamily="Consolas"
                       FontSize="13"
                       TextWrapping="Wrap" />

            <TextBlock Grid.Row="3"
                       Text="Username"
                       Style="{StaticResource TerminalLabelStyle}" />
            <TextBox x:Name="LoginUsernameText"
                     Grid.Row="4"
                     KeyDown="OnCredentialsKeyDown"
                     Style="{StaticResource TerminalTextBoxStyle}" />

            <TextBlock Grid.Row="5"
                       Margin="0,14,0,8"
                       Text="Password"
                       Style="{StaticResource TerminalLabelStyle}" />
            <PasswordBox x:Name="LoginPasswordBox"
                         Grid.Row="6"
                         KeyDown="OnCredentialsKeyDown"
                         Style="{StaticResource TerminalPasswordBoxStyle}" />

            <StackPanel Grid.Row="7"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        Margin="0,18,0,0">
                <Button x:Name="LoginButton"
                        Width="140"
                        IsDefault="True"
                        Background="#1A5C34"
                        BorderBrush="#44A46A"
                        Foreground="#E6FFEF"
                        Style="{StaticResource TerminalButtonStyle}"
                        Content="Sign In"
                        Click="OnLoginClick" />
                <Button x:Name="OpenCreateUserButton"
                        Width="164"
                        Margin="12,0,0,0"
                        Background="#154529"
                        BorderBrush="#37895A"
                        Foreground="#D7FFE7"
                        Style="{StaticResource TerminalButtonStyle}"
                        Content="Create User..."
                        Click="OnOpenCreateUserClick" />
                <Button x:Name="CancelButton"
                        Width="120"
                        Margin="12,0,0,0"
                        Background="#24332B"
                        BorderBrush="#436052"
                        Foreground="#D2E5DB"
                        Style="{StaticResource TerminalButtonStyle}"
                        Content="Cancel"
                        Click="OnCancelClick" />
            </StackPanel>

            <ProgressBar x:Name="LoginProgressBar"
                         Grid.Row="8"
                         Margin="0,14,0,0"
                         Height="12"
                         Minimum="0"
                         Maximum="100"
                         IsIndeterminate="True"
                         Visibility="Collapsed"
                         Foreground="#5EF5A0"
                         Background="#0D2418"
                         BorderBrush="#2D7D4C"
                         BorderThickness="1" />

            <TextBlock x:Name="StatusText"
                       Grid.Row="9"
                       Margin="0,12,0,0"
                       Foreground="#9CE7BA"
                       FontFamily="Consolas"
                       FontSize="14"
                       TextWrapping="Wrap" />
            </Grid>
        </Border>
    </Grid>
</Window>
