<Window x:Class="GalacticTrader.Desktop.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Galactic Trader // Auth Terminal"
        Width="500"
        Height="360"
        MinWidth="500"
        MinHeight="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#060C09">
    <Window.Resources>
        <Style x:Key="TerminalLabelStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="#78F2A4" />
            <Setter Property="FontFamily"
                    Value="Consolas" />
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="Margin"
                    Value="0,0,0,6" />
        </Style>

        <Style x:Key="TerminalTextBoxStyle"
               TargetType="TextBox">
            <Setter Property="Height"
                    Value="34" />
            <Setter Property="Padding"
                    Value="10,6" />
            <Setter Property="Background"
                    Value="#0E1A13" />
            <Setter Property="Foreground"
                    Value="#C6FFD9" />
            <Setter Property="BorderBrush"
                    Value="#2D7D4C" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="FontFamily"
                    Value="Consolas" />
        </Style>

        <Style x:Key="TerminalPasswordBoxStyle"
               TargetType="PasswordBox">
            <Setter Property="Height"
                    Value="34" />
            <Setter Property="Padding"
                    Value="10,6" />
            <Setter Property="Background"
                    Value="#0E1A13" />
            <Setter Property="Foreground"
                    Value="#C6FFD9" />
            <Setter Property="BorderBrush"
                    Value="#2D7D4C" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="FontFamily"
                    Value="Consolas" />
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Border CornerRadius="10"
                Background="#08120E"
                BorderBrush="#1B3829"
                BorderThickness="1" />
        <Rectangle Margin="1"
                   RadiusX="10"
                   RadiusY="10"
                   IsHitTestVisible="False">
            <Rectangle.Fill>
                <VisualBrush TileMode="Tile"
                            ViewportUnits="Absolute"
                            Viewport="0,0,5,5"
                            Opacity="0.08">
                    <VisualBrush.Visual>
                        <Rectangle Width="5"
                                   Height="5"
                                   Fill="#64FF9A" />
                    </VisualBrush.Visual>
                </VisualBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Border Margin="8"
                BorderBrush="#2D7D4C"
                BorderThickness="1.2"
                CornerRadius="8"
                Padding="14"
                Background="#07100C">
            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Foreground="#8EFFB5"
                       FontFamily="Consolas"
                       FontSize="19"
                       FontWeight="Bold"
                       Text="GALACTIC TRADER // AUTH TERMINAL" />
            <TextBlock Grid.Row="1"
                       Margin="0,4,0,0"
                       Foreground="#72BE91"
                       FontFamily="Consolas"
                       FontSize="12"
                       Text="Establish pilot credentials before launching command interface." />
            <TextBlock x:Name="ApiBaseUrlText"
                       Grid.Row="2"
                       Margin="0,4,0,16"
                       Foreground="#58D48C"
                       FontFamily="Consolas"
                       FontSize="11"
                       TextWrapping="Wrap" />

            <TextBlock Grid.Row="3"
                       Text="Username"
                       Style="{StaticResource TerminalLabelStyle}" />
            <TextBox x:Name="LoginUsernameText"
                     Grid.Row="4"
                     KeyDown="OnCredentialsKeyDown"
                     Style="{StaticResource TerminalTextBoxStyle}" />

            <TextBlock Grid.Row="5"
                       Margin="0,12,0,6"
                       Text="Password"
                       Style="{StaticResource TerminalLabelStyle}" />
            <PasswordBox x:Name="LoginPasswordBox"
                         Grid.Row="6"
                         KeyDown="OnCredentialsKeyDown"
                         Style="{StaticResource TerminalPasswordBoxStyle}" />

            <StackPanel Grid.Row="7"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        Margin="0,14,0,0">
                <Button x:Name="LoginButton"
                        Width="120"
                        Height="34"
                        IsDefault="True"
                        Background="#1A5C34"
                        BorderBrush="#44A46A"
                        Foreground="#E6FFEF"
                        FontFamily="Consolas"
                        FontWeight="SemiBold"
                        Content="Sign In"
                        Click="OnLoginClick" />
                <Button x:Name="OpenCreateUserButton"
                        Width="138"
                        Height="34"
                        Margin="10,0,0,0"
                        Background="#154529"
                        BorderBrush="#37895A"
                        Foreground="#D7FFE7"
                        FontFamily="Consolas"
                        FontWeight="SemiBold"
                        Content="Create User..."
                        Click="OnOpenCreateUserClick" />
                <Button x:Name="CancelButton"
                        Width="105"
                        Height="34"
                        Margin="10,0,0,0"
                        Background="#24332B"
                        BorderBrush="#436052"
                        Foreground="#D2E5DB"
                        FontFamily="Consolas"
                        FontWeight="SemiBold"
                        Content="Cancel"
                        Click="OnCancelClick" />
            </StackPanel>

            <TextBlock x:Name="StatusText"
                       Grid.Row="8"
                       Margin="0,12,0,0"
                       Foreground="#9CE7BA"
                       FontFamily="Consolas"
                       FontSize="11"
                       TextWrapping="Wrap" />
            </Grid>
        </Border>
    </Grid>
</Window>
