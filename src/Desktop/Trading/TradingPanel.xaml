<UserControl x:Class="GalacticTrader.Desktop.Trading.TradingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0"
                   Margin="0,0,0,10"
                   ItemHeight="66"
                   ItemWidth="156">
            <StackPanel Margin="0,0,10,0">
                <TextBlock Foreground="#B9CBE8"
                           Text="Market Listing Id" />
                <TextBox x:Name="ListingIdText"
                         Width="250"
                         Height="30"
                         Background="#101F39"
                         BorderBrush="#2E4A75"
                         Foreground="#EAF2FF"
                         Padding="8,4" />
            </StackPanel>
            <StackPanel Margin="0,0,10,0">
                <TextBlock Foreground="#B9CBE8"
                           Text="Quantity" />
                <TextBox x:Name="QuantityText"
                         Width="84"
                         Height="30"
                         Text="100"
                         TextChanged="OnQuantityTextChanged"
                         Background="#101F39"
                         BorderBrush="#2E4A75"
                         Foreground="#EAF2FF"
                         Padding="8,4" />
                <Slider x:Name="QuantitySlider"
                        Width="140"
                        Margin="0,4,0,0"
                        Minimum="1"
                        Maximum="100000"
                        Value="100"
                        TickFrequency="1000"
                        IsSnapToTickEnabled="False"
                        ValueChanged="OnQuantitySliderChanged" />
            </StackPanel>
            <StackPanel Margin="0,0,10,0">
                <TextBlock Foreground="#B9CBE8"
                           Text="Demand" />
                <TextBox x:Name="DemandText"
                         Width="72"
                         Height="30"
                         Text="1.00"
                         Background="#101F39"
                         BorderBrush="#2E4A75"
                         Foreground="#EAF2FF"
                         Padding="8,4" />
            </StackPanel>
            <StackPanel Margin="0,0,10,0">
                <TextBlock Foreground="#B9CBE8"
                           Text="Risk" />
                <TextBox x:Name="RiskText"
                         Width="72"
                         Height="30"
                         Text="0.05"
                         Background="#101F39"
                         BorderBrush="#2E4A75"
                         Foreground="#EAF2FF"
                         Padding="8,4" />
            </StackPanel>
            <StackPanel Margin="0,0,10,0">
                <TextBlock Foreground="#B9CBE8"
                           Text="Scarcity" />
                <TextBox x:Name="ScarcityText"
                         Width="72"
                         Height="30"
                         Text="0.00"
                         Background="#101F39"
                         BorderBrush="#2E4A75"
                         Foreground="#EAF2FF"
                         Padding="8,4" />
            </StackPanel>
            <StackPanel Margin="0,0,10,0">
                <TextBlock Foreground="#B9CBE8"
                           Text="Faction" />
                <TextBox x:Name="FactionText"
                         Width="72"
                         Height="30"
                         Text="0.00"
                         Background="#101F39"
                         BorderBrush="#2E4A75"
                         Foreground="#EAF2FF"
                         Padding="8,4" />
            </StackPanel>
            <StackPanel Margin="0,0,10,0">
                <TextBlock Foreground="#B9CBE8"
                           Text="Pirate" />
                <TextBox x:Name="PirateText"
                         Width="72"
                         Height="30"
                         Text="0.00"
                         Background="#101F39"
                         BorderBrush="#2E4A75"
                         Foreground="#EAF2FF"
                         Padding="8,4" />
            </StackPanel>
            <StackPanel Margin="0,0,10,0">
                <TextBlock Foreground="#B9CBE8"
                           Text="Monopoly" />
                <TextBox x:Name="MonopolyText"
                         Width="72"
                         Height="30"
                         Text="0.00"
                         Background="#101F39"
                         BorderBrush="#2E4A75"
                         Foreground="#EAF2FF"
                         Padding="8,4" />
            </StackPanel>
            <StackPanel Orientation="Horizontal"
                        Margin="0,20,0,0">
                <Button x:Name="PreviewButton"
                        Width="132"
                        Height="34"
                        Margin="0,0,8,0"
                        Background="#1F6FEB"
                        BorderBrush="#4A89F6"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Content="Preview Spread"
                        Click="OnPreviewClick" />
                <Button x:Name="RefreshButton"
                        Width="132"
                        Height="34"
                        Background="#00A86B"
                        BorderBrush="#20C284"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Content="Refresh Trades"
                        Click="OnRefreshTransactionsClick" />
            </StackPanel>
        </WrapPanel>

        <Border Grid.Row="1"
                Padding="10"
                Margin="0,0,0,10"
                BorderBrush="#2E4A75"
                BorderThickness="1"
                CornerRadius="6"
                Background="#0E203D">
            <DockPanel>
                <TextBlock x:Name="StatusText"
                           DockPanel.Dock="Top"
                           Foreground="#9DB7E2"
                           Margin="0,0,0,8"
                           Text="Load recent trades to establish fee baseline." />
                <WrapPanel>
                    <TextBlock Foreground="#C9D8F4"
                               Margin="0,0,8,0"
                               Text="Preview:" />
                    <TextBlock x:Name="PreviewSummaryText"
                               Foreground="#EAF2FF"
                               FontFamily="Consolas"
                               Text="No preview generated." />
                </WrapPanel>
                <TextBlock x:Name="SmugglingRiskText"
                           Margin="0,6,0,0"
                           Foreground="#EAF2FF"
                           FontFamily="Consolas"
                           Text="Smuggling Risk: --" />
            </DockPanel>
        </Border>

        <DataGrid Grid.Row="2"
                  x:Name="TransactionsGrid"
                  Background="#0C152A"
                  BorderBrush="#2F4B78"
                  Foreground="#DCE7FF"
                  HeadersVisibility="Column"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Action"
                                    Binding="{Binding Action}"
                                    Width="90" />
                <DataGridTextColumn Header="Qty"
                                    Binding="{Binding Quantity}"
                                    Width="70" />
                <DataGridTextColumn Header="Unit"
                                    Binding="{Binding UnitPrice, StringFormat={}{0:N2}}"
                                    Width="110" />
                <DataGridTextColumn Header="Tariff"
                                    Binding="{Binding TariffAmount, StringFormat={}{0:N2}}"
                                    Width="100" />
                <DataGridTextColumn Header="Total"
                                    Binding="{Binding TotalPrice, StringFormat={}{0:N2}}"
                                    Width="120" />
                <DataGridTextColumn Header="Status"
                                    Binding="{Binding Status}"
                                    Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
