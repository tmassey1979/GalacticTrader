<Window x:Class="GalacticTrader.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GalacticTrader.Desktop"
        mc:Ignorable="d"
        Title="Galactic Trader Command"
        Height="900"
        Width="1500"
        MinHeight="700"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#081225">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="180" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#111B33"
                BorderBrush="#2F4B78"
                BorderThickness="1"
                CornerRadius="12"
                Padding="10"
                Margin="0,0,0,10">
            <DockPanel>
                <Button x:Name="RefreshDashboardButton"
                        DockPanel.Dock="Right"
                        Width="150"
                        Height="34"
                        Margin="10,0,0,0"
                        Background="#1F6FEB"
                        BorderBrush="#4A89F6"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Content="Refresh Metrics"
                        Click="OnRefreshDashboardClick" />
                <WrapPanel VerticalAlignment="Center">
                    <TextBlock x:Name="PlayerMetricText"
                               Margin="0,0,20,0"
                               Foreground="#EAF2FF"
                               FontWeight="SemiBold"
                               Text="Player: -" />
                    <TextBlock x:Name="CreditsMetricText"
                               Margin="0,0,20,0"
                               Foreground="#CFDDFC"
                               Text="Credits: -" />
                    <TextBlock x:Name="NetWorthMetricText"
                               Margin="0,0,20,0"
                               Foreground="#CFDDFC"
                               Text="Net Worth: -" />
                    <TextBlock x:Name="ReputationMetricText"
                               Margin="0,0,20,0"
                               Foreground="#CFDDFC"
                               Text="Reputation: -" />
                    <TextBlock x:Name="FleetMetricText"
                               Margin="0,0,20,0"
                               Foreground="#CFDDFC"
                               Text="Fleet: -" />
                    <TextBlock x:Name="ProtectionMetricText"
                               Margin="0,0,20,0"
                               Foreground="#CFDDFC"
                               Text="Protection: -" />
                    <TextBlock x:Name="RoutesMetricText"
                               Margin="0,0,20,0"
                               Foreground="#CFDDFC"
                               Text="Routes: -" />
                    <TextBlock x:Name="EconomicIndexMetricText"
                               Margin="0,0,20,0"
                               Foreground="#CFDDFC"
                               Text="GEI: -" />
                    <TextBlock x:Name="AlertsMetricText"
                               Foreground="#CFDDFC"
                               Text="Alerts: -" />
                </WrapPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#111B33"
                    BorderBrush="#2F4B78"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top"
                               Text="Galactic Trader"
                               Foreground="#E8F0FF"
                               FontSize="24"
                               FontWeight="SemiBold" />

                    <TextBlock DockPanel.Dock="Top"
                               Margin="0,6,0,12"
                               Text="Desktop command interface with tactical 3D starmap"
                               Foreground="#A4B8DD"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="BreadcrumbText"
                               DockPanel.Dock="Top"
                               Margin="0,0,0,12"
                               Foreground="#7FA3D8"
                               FontSize="12"
                               Text="Command / Dashboard" />

                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Vertical"
                                Margin="0,0,0,16">
                        <TextBlock Text="Camera Controls"
                                   Foreground="#D5E3FF"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />

                        <TextBlock Text="Yaw"
                                   Foreground="#A4B8DD" />
                        <Slider x:Name="YawSlider"
                                Minimum="0"
                                Maximum="360"
                                Value="48"
                                TickFrequency="30"
                                ValueChanged="OnCameraSliderChanged" />

                        <TextBlock Text="Pitch"
                                   Foreground="#A4B8DD"
                                   Margin="0,8,0,0" />
                        <Slider x:Name="PitchSlider"
                                Minimum="-80"
                                Maximum="-5"
                                Value="-24"
                                TickFrequency="5"
                                ValueChanged="OnCameraSliderChanged" />

                        <TextBlock Text="Zoom"
                                   Foreground="#A4B8DD"
                                   Margin="0,8,0,0" />
                        <Slider x:Name="ZoomSlider"
                                Minimum="60"
                                Maximum="420"
                                Value="220"
                                TickFrequency="20"
                                ValueChanged="OnCameraSliderChanged" />

                        <Button Margin="0,12,0,0"
                                Padding="10,6"
                                Background="#1F6FEB"
                                BorderBrush="#4A89F6"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Content="Reset Camera"
                                Click="OnResetCameraClick" />
                    </StackPanel>

                    <TextBlock DockPanel.Dock="Top"
                               Text="Key Trade Routes"
                               Foreground="#D5E3FF"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />

                    <ListBox x:Name="RouteList"
                             DisplayMemberPath="Name"
                             SelectionChanged="OnRouteSelectionChanged"
                             Background="#0C152A"
                             BorderBrush="#2F4B78"
                             Foreground="#DCE7FF" />

                    <TabControl x:Name="ModuleTabs"
                                DockPanel.Dock="Bottom"
                                Margin="0,16,0,0"
                                Height="190"
                                Background="#0D1A33"
                                BorderBrush="#2F4B78"
                                SelectionChanged="OnModuleTabSelectionChanged">
                        <TabItem Header="Dashboard">
                            <ContentControl x:Name="DashboardHost"
                                            Margin="12" />
                        </TabItem>
                        <TabItem Header="Trading">
                            <ContentControl x:Name="TradingHost"
                                            Margin="12" />
                        </TabItem>
                        <TabItem Header="Routes">
                            <ContentControl x:Name="RoutesHost"
                                            Margin="12" />
                        </TabItem>
                        <TabItem Header="Battles">
                            <ContentControl x:Name="BattlesHost"
                                            Margin="12" />
                        </TabItem>
                        <TabItem Header="Fleet">
                            <ContentControl x:Name="FleetHost"
                                            Margin="12" />
                        </TabItem>
                        <TabItem Header="Intel">
                            <ContentControl x:Name="IntelHost"
                                            Margin="12" />
                        </TabItem>
                        <TabItem Header="Market Intel">
                            <ContentControl x:Name="MarketIntelHost"
                                            Margin="12" />
                        </TabItem>
                        <TabItem Header="Services">
                            <ContentControl x:Name="ServicesHost"
                                            Margin="12" />
                        </TabItem>
                        <TabItem Header="Reputation">
                            <ContentControl x:Name="ReputationHost"
                                            Margin="12" />
                        </TabItem>
                        <TabItem Header="Territory">
                            <ContentControl x:Name="TerritoryHost"
                                            Margin="12" />
                        </TabItem>
                        <TabItem Header="Analytics">
                            <ContentControl x:Name="AnalyticsHost"
                                            Margin="12" />
                        </TabItem>
                        <TabItem Header="Settings">
                            <ContentControl x:Name="SettingsHost"
                                            Margin="12" />
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="#0B1830"
                    BorderBrush="#2F4B78"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="8">
                <Grid>
                    <TextBlock Margin="8"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top"
                               Foreground="#E8F0FF"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Text="Starmap 3D View" />

                    <TextBlock Margin="8"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Top"
                               Foreground="#A4B8DD"
                               Text="Drag: orbit | Wheel: zoom | Select route: focus" />

                    <Viewport3D x:Name="StarViewport"
                                Margin="0,34,0,0"
                                ClipToBounds="True">
                        <Viewport3D.Camera>
                            <PerspectiveCamera x:Name="SceneCamera"
                                               Position="180,110,180"
                                               LookDirection="-180,-110,-180"
                                               UpDirection="0,1,0"
                                               FieldOfView="55" />
                        </Viewport3D.Camera>

                        <ModelVisual3D>
                            <ModelVisual3D.Content>
                                <Model3DGroup>
                                    <AmbientLight Color="#3C537A" />
                                    <DirectionalLight Color="#B6CDFF"
                                                      Direction="-1,-1,-2" />
                                    <DirectionalLight Color="#7BA0FF"
                                                      Direction="1,-0.5,-1" />
                                </Model3DGroup>
                            </ModelVisual3D.Content>
                        </ModelVisual3D>

                        <ModelVisual3D x:Name="SceneModels" />
                    </Viewport3D>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="0,10,0,0"
                Background="#111B33"
                BorderBrush="#2F4B78"
                BorderThickness="1"
                CornerRadius="12"
                Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0"
                           Margin="0,0,0,8">
                    <Button x:Name="ExportEventFeedButton"
                            DockPanel.Dock="Right"
                            Width="130"
                            Height="30"
                            Margin="6,0,0,0"
                            Background="#2D3D57"
                            BorderBrush="#4C607F"
                            Foreground="#EAF2FF"
                            FontWeight="SemiBold"
                            Content="Export Events"
                            Click="OnExportEventFeedClick" />
                    <Button x:Name="RefreshEventFeedButton"
                            DockPanel.Dock="Right"
                            Width="150"
                            Height="30"
                            Background="#00A86B"
                            BorderBrush="#20C284"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Content="Refresh Events"
                            Click="OnRefreshEventFeedClick" />
                    <ComboBox x:Name="EventCategoryFilter"
                              Width="180"
                              Height="30"
                              Background="#101F39"
                              BorderBrush="#2E4A75"
                              Foreground="#EAF2FF"
                              SelectionChanged="OnEventFilterChanged">
                        <ComboBoxItem IsSelected="True"
                                      Content="All" />
                        <ComboBoxItem Content="Trade" />
                        <ComboBoxItem Content="Combat" />
                        <ComboBoxItem Content="Intel" />
                        <ComboBoxItem Content="Territory" />
                    </ComboBox>
                    <TextBox x:Name="EventKeywordFilter"
                             Width="200"
                             Height="30"
                             Margin="8,0,0,0"
                             Background="#101F39"
                             BorderBrush="#2E4A75"
                             Foreground="#EAF2FF"
                             VerticalContentAlignment="Center"
                             TextChanged="OnEventKeywordTextChanged"
                             ToolTip="Keyword filter" />
                    <ComboBox x:Name="EventTimeWindowFilter"
                              Width="120"
                              Height="30"
                              Margin="8,0,0,0"
                              Background="#101F39"
                              BorderBrush="#2E4A75"
                              Foreground="#EAF2FF"
                              SelectionChanged="OnEventFilterChanged">
                        <ComboBoxItem IsSelected="True"
                                      Content="All Time" />
                        <ComboBoxItem Content="Last 1h" />
                        <ComboBoxItem Content="Last 24h" />
                        <ComboBoxItem Content="Last 7d" />
                    </ComboBox>
                </DockPanel>

                <DataGrid Grid.Row="1"
                          x:Name="EventFeedGrid"
                          Background="#0C152A"
                          BorderBrush="#2F4B78"
                          Foreground="#DCE7FF"
                          HeadersVisibility="Column"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time (UTC)"
                                            Binding="{Binding OccurredAtUtc, StringFormat={}{0:u}}"
                                            Width="180" />
                        <DataGridTextColumn Header="Category"
                                            Binding="{Binding Category}"
                                            Width="80" />
                        <DataGridTextColumn Header="Title"
                                            Binding="{Binding Title}"
                                            Width="220" />
                        <DataGridTextColumn Header="Detail"
                                            Binding="{Binding Detail}"
                                            Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Window>
