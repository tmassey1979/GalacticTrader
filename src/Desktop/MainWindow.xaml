<Window x:Class="GalacticTrader.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GalacticTrader.Desktop"
        mc:Ignorable="d"
        Title="Galactic Trader Command"
        Height="900"
        Width="1500"
        MinHeight="700"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#081225">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#111B33"
                BorderBrush="#2F4B78"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Top"
                           Text="Galactic Trader"
                           Foreground="#E8F0FF"
                           FontSize="24"
                           FontWeight="SemiBold" />

                <TextBlock DockPanel.Dock="Top"
                           Margin="0,6,0,12"
                           Text="Desktop command interface with tactical 3D starmap"
                           Foreground="#A4B8DD"
                           TextWrapping="Wrap" />

                <StackPanel DockPanel.Dock="Top"
                            Orientation="Vertical"
                            Margin="0,0,0,16">
                    <TextBlock Text="Camera Controls"
                               Foreground="#D5E3FF"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />

                    <TextBlock Text="Yaw"
                               Foreground="#A4B8DD" />
                    <Slider x:Name="YawSlider"
                            Minimum="0"
                            Maximum="360"
                            Value="48"
                            TickFrequency="30"
                            ValueChanged="OnCameraSliderChanged" />

                    <TextBlock Text="Pitch"
                               Foreground="#A4B8DD"
                               Margin="0,8,0,0" />
                    <Slider x:Name="PitchSlider"
                            Minimum="-80"
                            Maximum="-5"
                            Value="-24"
                            TickFrequency="5"
                            ValueChanged="OnCameraSliderChanged" />

                    <TextBlock Text="Zoom"
                               Foreground="#A4B8DD"
                               Margin="0,8,0,0" />
                    <Slider x:Name="ZoomSlider"
                            Minimum="60"
                            Maximum="420"
                            Value="220"
                            TickFrequency="20"
                            ValueChanged="OnCameraSliderChanged" />

                    <Button Margin="0,12,0,0"
                            Padding="10,6"
                            Background="#1F6FEB"
                            BorderBrush="#4A89F6"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Content="Reset Camera"
                            Click="OnResetCameraClick" />
                </StackPanel>

                <TextBlock DockPanel.Dock="Top"
                           Text="Key Trade Routes"
                           Foreground="#D5E3FF"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />

                <ListBox x:Name="RouteList"
                         DisplayMemberPath="Name"
                         SelectionChanged="OnRouteSelectionChanged"
                         Background="#0C152A"
                         BorderBrush="#2F4B78"
                         Foreground="#DCE7FF" />

                <TabControl DockPanel.Dock="Bottom"
                            Margin="0,16,0,0"
                            Height="190"
                            Background="#0D1A33"
                            BorderBrush="#2F4B78">
                    <TabItem Header="Dashboard">
                        <TextBlock Margin="12"
                                   Foreground="#CFDDFC"
                                   TextWrapping="Wrap"
                                   Text="Live command summary: active contracts, fuel budget, and station inventory snapshots." />
                    </TabItem>
                    <TabItem Header="Trading">
                        <TextBlock Margin="12"
                                   Foreground="#CFDDFC"
                                   TextWrapping="Wrap"
                                   Text="Trade execution panel placeholder for buy/sell orders with spread and fee previews." />
                    </TabItem>
                    <TabItem Header="Fleet">
                        <TextBlock Margin="12"
                                   Foreground="#CFDDFC"
                                   TextWrapping="Wrap"
                                   Text="Fleet management placeholder for ship loadouts, escorts, and crew assignments." />
                    </TabItem>
                    <TabItem Header="Intel">
                        <TextBlock Margin="12"
                                   Foreground="#CFDDFC"
                                   TextWrapping="Wrap"
                                   Text="Intelligence and reputation placeholder for faction alerts and threat movement." />
                    </TabItem>
                </TabControl>
            </DockPanel>
        </Border>

        <Border Grid.Column="2"
                Background="#0B1830"
                BorderBrush="#2F4B78"
                BorderThickness="1"
                CornerRadius="12"
                Padding="8">
            <Grid>
                <TextBlock Margin="8"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           Foreground="#E8F0FF"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Text="Starmap 3D View" />

                <TextBlock Margin="8"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top"
                           Foreground="#A4B8DD"
                           Text="Drag: orbit | Wheel: zoom | Select route: focus" />

                <Viewport3D x:Name="StarViewport"
                            Margin="0,34,0,0"
                            ClipToBounds="True">
                    <Viewport3D.Camera>
                        <PerspectiveCamera x:Name="SceneCamera"
                                           Position="180,110,180"
                                           LookDirection="-180,-110,-180"
                                           UpDirection="0,1,0"
                                           FieldOfView="55" />
                    </Viewport3D.Camera>

                    <ModelVisual3D>
                        <ModelVisual3D.Content>
                            <Model3DGroup>
                                <AmbientLight Color="#3C537A" />
                                <DirectionalLight Color="#B6CDFF"
                                                  Direction="-1,-1,-2" />
                                <DirectionalLight Color="#7BA0FF"
                                                  Direction="1,-0.5,-1" />
                            </Model3DGroup>
                        </ModelVisual3D.Content>
                    </ModelVisual3D>

                    <ModelVisual3D x:Name="SceneModels" />
                </Viewport3D>
            </Grid>
        </Border>
    </Grid>
</Window>
