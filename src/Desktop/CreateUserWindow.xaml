<Window x:Class="GalacticTrader.Desktop.CreateUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create User // Registration Terminal"
        Width="620"
        Height="640"
        MinWidth="560"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#060C09">
    <Window.Resources>
        <Style x:Key="LabelStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="#7AF7A7" />
            <Setter Property="FontFamily"
                    Value="Consolas" />
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="Margin"
                    Value="0,0,0,6" />
        </Style>

        <Style x:Key="TextBoxStyle"
               TargetType="TextBox">
            <Setter Property="Height"
                    Value="34" />
            <Setter Property="Padding"
                    Value="10,6" />
            <Setter Property="Background"
                    Value="#0F1D15" />
            <Setter Property="Foreground"
                    Value="#D1FFE1" />
            <Setter Property="BorderBrush"
                    Value="#2D7D4C" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="FontFamily"
                    Value="Consolas" />
        </Style>

        <Style x:Key="PasswordBoxStyle"
               TargetType="PasswordBox">
            <Setter Property="Height"
                    Value="34" />
            <Setter Property="Padding"
                    Value="10,6" />
            <Setter Property="Background"
                    Value="#0F1D15" />
            <Setter Property="Foreground"
                    Value="#D1FFE1" />
            <Setter Property="BorderBrush"
                    Value="#2D7D4C" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="FontFamily"
                    Value="Consolas" />
        </Style>

        <Style x:Key="ComboBoxStyle"
               TargetType="ComboBox">
            <Setter Property="Height"
                    Value="34" />
            <Setter Property="Padding"
                    Value="8,4" />
            <Setter Property="Background"
                    Value="#0F1D15" />
            <Setter Property="Foreground"
                    Value="#D1FFE1" />
            <Setter Property="BorderBrush"
                    Value="#2D7D4C" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="FontFamily"
                    Value="Consolas" />
        </Style>
    </Window.Resources>

    <Border Margin="14"
            BorderBrush="#2D7D4C"
            BorderThickness="1.3"
            CornerRadius="12"
            Padding="14"
            Background="#07100C">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Foreground="#8EFFB5"
                       FontFamily="Consolas"
                       FontSize="22"
                       FontWeight="Bold"
                       Text="CREATE USER // PROFILE BOOTSTRAP" />
            <TextBlock Grid.Row="1"
                       Margin="0,4,0,12"
                       Foreground="#74C996"
                       FontFamily="Consolas"
                       FontSize="11"
                       Text="Capture key profile fields for identity registration." />

            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Grid.Column="0">
                        <TextBlock Text="First Name"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBox x:Name="FirstNameText"
                                 Style="{StaticResource TextBoxStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Row="0"
                                Grid.Column="2">
                        <TextBlock Text="Last Name"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBox x:Name="LastNameText"
                                 Style="{StaticResource TextBoxStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,12,0,0">
                        <TextBlock Text="Middle Name"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBox x:Name="MiddleNameText"
                                 Style="{StaticResource TextBoxStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1"
                                Grid.Column="2"
                                Margin="0,12,0,0">
                        <TextBlock Text="Nickname"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBox x:Name="NicknameText"
                                 Style="{StaticResource TextBoxStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Grid.Column="0"
                                Margin="0,12,0,0">
                        <TextBlock Text="Birthdate (YYYY-MM-DD)"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBox x:Name="BirthdateText"
                                 Style="{StaticResource TextBoxStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Row="2"
                                Grid.Column="2"
                                Margin="0,12,0,0">
                        <TextBlock Text="Gender"
                                   Style="{StaticResource LabelStyle}" />
                        <ComboBox x:Name="GenderCombo"
                                  Style="{StaticResource ComboBoxStyle}"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="Prefer not to say" />
                            <ComboBoxItem Content="Woman" />
                            <ComboBoxItem Content="Man" />
                            <ComboBoxItem Content="Non-binary" />
                            <ComboBoxItem Content="Trans woman" />
                            <ComboBoxItem Content="Trans man" />
                            <ComboBoxItem Content="Genderqueer" />
                            <ComboBoxItem Content="Genderfluid" />
                            <ComboBoxItem Content="Agender" />
                            <ComboBoxItem Content="Intersex" />
                            <ComboBoxItem Content="Other" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="3"
                                Grid.Column="2"
                                Margin="0,12,0,0">
                        <TextBlock Text="Pronouns"
                                  Style="{StaticResource LabelStyle}" />
                        <ComboBox x:Name="PronounsCombo"
                                  Style="{StaticResource ComboBoxStyle}"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="Prefer not to say" />
                            <ComboBoxItem Content="she/her" />
                            <ComboBoxItem Content="he/him" />
                            <ComboBoxItem Content="they/them" />
                            <ComboBoxItem Content="she/they" />
                            <ComboBoxItem Content="he/they" />
                            <ComboBoxItem Content="xe/xem" />
                            <ComboBoxItem Content="ze/zir" />
                            <ComboBoxItem Content="any pronouns" />
                            <ComboBoxItem Content="use my name only" />
                            <ComboBoxItem Content="other" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="4"
                                Grid.Column="0"
                                Margin="0,12,0,0">
                        <TextBlock Text="Phone Number"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBox x:Name="PhoneNumberText"
                                 Style="{StaticResource TextBoxStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="5"
                                Grid.Column="0"
                                Margin="0,12,0,0">
                        <TextBlock Text="Locale"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBox x:Name="LocaleText"
                                 Style="{StaticResource TextBoxStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Row="5"
                                Grid.Column="2"
                                Margin="0,12,0,0">
                        <TextBlock Text="Time Zone"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBox x:Name="TimeZoneText"
                                 Style="{StaticResource TextBoxStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="6"
                                Grid.ColumnSpan="3"
                                Margin="0,12,0,0">
                        <TextBlock Text="Website"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBox x:Name="WebsiteText"
                                 Style="{StaticResource TextBoxStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="7"
                                Grid.Column="0"
                                Margin="0,12,0,0">
                        <TextBlock Text="Username"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBox x:Name="UsernameText"
                                 Style="{StaticResource TextBoxStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Row="7"
                                Grid.Column="2"
                                Margin="0,12,0,0">
                        <TextBlock Text="Email"
                                   Style="{StaticResource LabelStyle}" />
                        <TextBox x:Name="EmailText"
                                 Style="{StaticResource TextBoxStyle}" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <StackPanel Grid.Row="3"
                        Margin="0,12,0,0">
                <TextBlock Text="Password"
                           Style="{StaticResource LabelStyle}" />
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource PasswordBoxStyle}" />
            </StackPanel>

            <DockPanel Grid.Row="4"
                       Margin="0,14,0,0">
                <Button x:Name="CreateButton"
                        DockPanel.Dock="Left"
                        Width="130"
                        Height="34"
                        Background="#1A5C34"
                        BorderBrush="#44A46A"
                        Foreground="#E6FFEF"
                        FontFamily="Consolas"
                        FontWeight="SemiBold"
                        Content="Create User"
                        Click="OnCreateClick" />
                <Button x:Name="CancelButton"
                        DockPanel.Dock="Left"
                        Width="105"
                        Height="34"
                        Margin="10,0,0,0"
                        Background="#24332B"
                        BorderBrush="#436052"
                        Foreground="#D2E5DB"
                        FontFamily="Consolas"
                        FontWeight="SemiBold"
                        Content="Cancel"
                        Click="OnCancelClick" />
                <TextBlock x:Name="StatusText"
                           Margin="16,8,0,0"
                           Foreground="#9CE7BA"
                           FontFamily="Consolas"
                           FontSize="11"
                           TextWrapping="Wrap" />
            </DockPanel>
        </Grid>
    </Border>
</Window>
