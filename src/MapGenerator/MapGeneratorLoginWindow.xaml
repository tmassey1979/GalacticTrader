<Window x:Class="GalacticTrader.MapGenerator.MapGeneratorLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Map Generator Sign In"
        Width="460"
        Height="330"
        MinWidth="460"
        MinHeight="330"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#071324">
    <Grid Margin="14">
        <Border Background="#0E1B33"
                BorderBrush="#2D4B78"
                BorderThickness="1"
                CornerRadius="12"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Map Generator Authentication"
                           Foreground="#E9F2FF"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <TextBlock Grid.Row="1"
                           Margin="0,4,0,12"
                           Foreground="#A3B8DD"
                           Text="Authenticate to receive a bearer token for map publishing." />

                <TextBlock Grid.Row="2"
                           Text="Username"
                           Foreground="#B9CBE8" />
                <TextBox x:Name="UsernameText"
                         Grid.Row="3"
                         Margin="0,6,0,10"
                         Height="34"
                         Padding="8,6"
                         Background="#12223E"
                         BorderBrush="#35598D"
                         Foreground="#EBF4FF"
                         FontFamily="Consolas" />

                <TextBlock Grid.Row="4"
                           Text="Password"
                           Foreground="#B9CBE8" />
                <PasswordBox x:Name="PasswordText"
                             Grid.Row="5"
                             Margin="0,6,0,0"
                             Height="34"
                             Padding="8,6"
                             Background="#12223E"
                             BorderBrush="#35598D"
                             Foreground="#EBF4FF"
                             FontFamily="Consolas" />

                <DockPanel Grid.Row="6"
                           Margin="0,14,0,0">
                    <Button x:Name="LoginButton"
                            DockPanel.Dock="Left"
                            Width="115"
                            Height="34"
                            IsDefault="True"
                            Background="#1F6FEB"
                            BorderBrush="#4A89F6"
                            Foreground="#FFFFFF"
                            FontWeight="SemiBold"
                            Content="Sign In"
                            Click="OnLoginClick" />
                    <Button x:Name="CancelButton"
                            DockPanel.Dock="Left"
                            Width="95"
                            Height="34"
                            Margin="10,0,0,0"
                            IsCancel="True"
                            Background="#2D3D57"
                            BorderBrush="#4C607F"
                            Foreground="#EAF2FF"
                            FontWeight="SemiBold"
                            Content="Cancel"
                            Click="OnCancelClick" />
                    <TextBlock x:Name="StatusText"
                               Margin="14,8,0,0"
                               Foreground="#7DF1A6"
                               FontFamily="Consolas"
                               TextWrapping="Wrap" />
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
