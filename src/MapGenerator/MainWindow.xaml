<Window x:Class="GalacticTrader.MapGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Galactic Trader Map Generator"
        Width="1220"
        Height="760"
        MinWidth="1060"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="#071324">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#0E1B33"
                BorderBrush="#2D4B78"
                BorderThickness="1"
                CornerRadius="12"
                Padding="14">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Map Generation Controls"
                               Foreground="#E9F2FF"
                               FontSize="23"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Generate sectors/routes and publish directly to the navigation API."
                               Margin="0,6,0,12"
                               Foreground="#A3B8DD"
                               TextWrapping="Wrap" />

                    <TextBlock Text="API Base URL"
                               Foreground="#B9CBE8" />
                    <TextBox x:Name="ApiBaseUrlText"
                             Margin="0,6,0,12"
                             Height="34"
                             Padding="8,6"
                             Background="#12223E"
                             BorderBrush="#35598D"
                             Foreground="#EBF4FF"
                             FontFamily="Consolas" />

                    <TextBlock Text="Bearer Token (Optional)"
                               Foreground="#B9CBE8" />
                    <TextBox x:Name="ApiTokenText"
                             Margin="0,6,0,12"
                             Height="34"
                             Padding="8,6"
                             Background="#12223E"
                             BorderBrush="#35598D"
                             Foreground="#EBF4FF"
                             FontFamily="Consolas" />

                    <TextBlock Text="Seed"
                               Foreground="#B9CBE8" />
                    <TextBox x:Name="SeedText"
                             Margin="0,6,0,12"
                             Height="34"
                             Padding="8,6"
                             Background="#12223E"
                             BorderBrush="#35598D"
                             Foreground="#EBF4FF"
                             FontFamily="Consolas" />

                    <TextBlock Text="Sector Count"
                               Foreground="#B9CBE8" />
                    <TextBox x:Name="SectorCountText"
                             Margin="0,6,0,12"
                             Height="34"
                             Padding="8,6"
                             Background="#12223E"
                             BorderBrush="#35598D"
                             Foreground="#EBF4FF"
                             FontFamily="Consolas" />

                    <TextBlock Text="Route Density (1-4)"
                               Foreground="#B9CBE8" />
                    <TextBox x:Name="RouteDensityText"
                             Margin="0,6,0,12"
                             Height="34"
                             Padding="8,6"
                             Background="#12223E"
                             BorderBrush="#35598D"
                             Foreground="#EBF4FF"
                             FontFamily="Consolas" />

                    <CheckBox x:Name="ReplaceExistingCheck"
                              Margin="0,2,0,10"
                              Foreground="#D9E7FF"
                              IsChecked="True"
                              Content="Replace existing map data before publishing" />

                    <WrapPanel Margin="0,4,0,10">
                        <Button x:Name="GenerateButton"
                                Width="156"
                                Height="36"
                                Margin="0,0,8,0"
                                Background="#1F6FEB"
                                BorderBrush="#4A89F6"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Content="Generate Preview"
                                Click="OnGenerateClick" />
                        <Button x:Name="PublishButton"
                                Width="156"
                                Height="36"
                                Background="#00A86B"
                                BorderBrush="#23C88A"
                                Foreground="White"
                                FontWeight="SemiBold"
                                Content="Publish To DB"
                                Click="OnPublishClick" />
                    </WrapPanel>

                    <Button x:Name="LoadCurrentButton"
                            Width="320"
                            Height="34"
                            Margin="0,0,0,10"
                            Background="#2D3D57"
                            BorderBrush="#4C607F"
                            Foreground="#EAF2FF"
                            FontWeight="SemiBold"
                            Content="Load Current Map"
                            Click="OnLoadCurrentClick" />

                    <TextBlock x:Name="SummaryText"
                               Foreground="#93B9FF"
                               FontFamily="Consolas"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border DockPanel.Dock="Bottom"
                        Margin="0,14,0,0"
                        Background="#0A172D"
                        BorderBrush="#294A74"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10">
                    <TextBlock x:Name="StatusText"
                               Foreground="#7DF1A6"
                               FontFamily="Consolas"
                               TextWrapping="Wrap"
                               MinHeight="84" />
                </Border>
            </DockPanel>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="#0E1B33"
                    BorderBrush="#2D4B78"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="10">
                <Grid>
                    <TextBlock Text="Generated Sectors"
                               Foreground="#E9F2FF"
                               FontSize="17"
                               FontWeight="SemiBold" />
                    <ListView x:Name="SectorList"
                              Margin="0,30,0,0"
                              Background="#11203B"
                              BorderBrush="#35598D"
                              Foreground="#DDEBFF" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Background="#0E1B33"
                    BorderBrush="#2D4B78"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="10">
                <Grid>
                    <TextBlock Text="Generated Routes"
                               Foreground="#E9F2FF"
                               FontSize="17"
                               FontWeight="SemiBold" />
                    <ListView x:Name="RouteList"
                              Margin="0,30,0,0"
                              Background="#11203B"
                              BorderBrush="#35598D"
                              Foreground="#DDEBFF" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
