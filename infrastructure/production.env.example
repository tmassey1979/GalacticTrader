ASPNETCORE_ENVIRONMENT=Production
DB_PASSWORD=SetStrongProductionSecret
KEYCLOAK_PASSWORD=SetStrongProductionSecret
GRAFANA_PASSWORD=SetStrongProductionSecret
API_IMAGE=ghcr.io/tmassey1979/galactictrader/api:latest
VAULT_ENABLED=true
VAULT_ADDRESS=https://vault-prod.example.com
